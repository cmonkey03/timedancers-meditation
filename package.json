{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "timedancers-meditation",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "EXPO_ROUTER_DISABLE_RN_NAVIGATION_CHECK=1 expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "lint": "expo lint",
    "test": "vitest --run",
    "detox:build": "detox build -c ios.debug",
    "detox:test": "detox test -c ios.debug",
    "detox:test:meditation": "detox test -c ios.debug e2e/meditation.e2e.ts",
    "detox:test:settings": "detox test -c ios.debug e2e/settings.e2e.ts",
    "detox:test:onboarding": "detox test -c ios.debug e2e/onboarding.e2e.ts",
    "e2e": "./scripts/run-e2e-tests.sh",
    "e2e:verbose": "./scripts/run-e2e-tests.sh --verbose",
    "e2e:skip-build": "./scripts/run-e2e-tests.sh --skip-build",
    "e2e:skip-unit": "./scripts/run-e2e-tests.sh --skip-unit",
    "e2e:meditation": "./scripts/run-e2e-tests.sh --suite meditation",
    "e2e:settings": "./scripts/run-e2e-tests.sh --suite settings",
    "e2e:onboarding": "./scripts/run-e2e-tests.sh --suite onboarding",
    "test:all": "./scripts/run-e2e-tests.sh",
    "test:unit-only": "npm test",
    "test:e2e-only": "./scripts/run-e2e-tests.sh --skip-unit"
  },
  "dependencies": {
    "@expo-google-fonts/cinzel": "^0.4.2",
    "@expo-google-fonts/inter": "^0.4.2",
    "@expo/metro-runtime": "~57.0.5",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-picker/picker": "2.11.4",
    "@react-navigation/native": "^7.3.8",
    "expo": "^57.0.6",
    "expo-asset": "~57.0.5",
    "expo-audio": "~57.0.2",
    "expo-constants": "~57.0.5",
    "expo-dev-client": "~57.0.6",
    "expo-font": "~57.0.1",
    "expo-haptics": "~57.0.1",
    "expo-image": "~57.0.1",
    "expo-keep-awake": "~57.0.1",
    "expo-linear-gradient": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-notifications": "~57.0.5",
    "expo-router": "~57.0.6",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "expo-symbols": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "expo-web-browser": "~57.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-onboarding-swiper": "^1.4.0",
    "react-native-pager-view": "8.0.2",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "~0.21.2",
    "react-native-worklets": "0.10.0"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.2.4",
    "@types/react-native-onboarding-swiper": "^1.1.9",
    "@vitest/ui": "^3.2.7",
    "detox": "^20.51.4",
    "eslint": "^9.39.5",
    "eslint-config-expo": "~57.0.0",
    "jest": "^29.7.0",
    "jsdom": "^27.0.1",
    "react-test-renderer": "19.1.0",
    "typescript": "~6.0.3",
    "vitest": "^3.2.7"
  },
  "overrides": {
    "uuid": "^11.1.1"
  },
  "private": true
}
